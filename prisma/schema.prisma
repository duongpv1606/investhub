// ============================================
// INVESTHUB - Prisma Schema
// Database: PostgreSQL (Supabase)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== USERS ====================
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile?
  portfolio     Portfolio?
  watchlists    Watchlist[]
  subscription  Subscription?
  aiChats       AIChat[]
  articles      Article[]

  @@map("users")
}

enum UserRole {
  USER
  PREMIUM
  ADMIN
}

// ==================== PROFILES ====================
model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  location        String?
  website         String?
  riskTolerance   RiskLevel @default(MODERATE)
  preferredCurrency String  @default("USD")
  notifications   Json     @default("{\"email\":true,\"priceAlerts\":true,\"news\":true}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

enum RiskLevel {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

// ==================== ARTICLES ====================
model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  views       Int      @default(0)
  readTime    Int      @default(5)
  authorId    String
  categoryId  String
  tags        String[]
  metadata    Json?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])

  @@map("articles")
}

// ==================== CATEGORIES ====================
model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  icon        String?
  createdAt   DateTime  @default(now())

  articles    Article[]

  @@map("categories")
}

// ==================== PORTFOLIOS ====================
model Portfolio {
  id          String    @id @default(cuid())
  userId      String    @unique
  name        String    @default("My Portfolio")
  description String?
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PortfolioItem[]

  @@map("portfolios")
}

model PortfolioItem {
  id           String    @id @default(cuid())
  portfolioId  String
  symbol       String
  name         String
  assetType    AssetType
  quantity     Float
  avgBuyPrice  Float
  notes        String?
  transactions Transaction[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
  @@map("portfolio_items")
}

enum AssetType {
  STOCK
  CRYPTO
  ETF
  FOREX
}

model Transaction {
  id              String          @id @default(cuid())
  portfolioItemId String
  type            TransactionType
  quantity        Float
  price           Float
  fee             Float           @default(0)
  notes           String?
  executedAt      DateTime        @default(now())
  createdAt       DateTime        @default(now())

  portfolioItem   PortfolioItem   @relation(fields: [portfolioItemId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum TransactionType {
  BUY
  SELL
  TRANSFER_IN
  TRANSFER_OUT
}

// ==================== WATCHLISTS ====================
model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Watchlist")
  items     WatchlistItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("watchlists")
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  symbol      String
  name        String
  assetType   AssetType
  alertPrice  Float?
  notes       String?
  addedAt     DateTime  @default(now())

  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
  @@map("watchlist_items")
}

// ==================== SUBSCRIPTIONS ====================
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

// ==================== AI CHATS ====================
model AIChat {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New Chat")
  messages  Json      @default("[]")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_chats")
}

// ==================== PRICE ALERTS ====================
model PriceAlert {
  id         String     @id @default(cuid())
  userId     String
  symbol     String
  assetType  AssetType
  condition  String     // "above" | "below"
  targetPrice Float
  triggered  Boolean    @default(false)
  triggeredAt DateTime?
  createdAt  DateTime   @default(now())

  @@map("price_alerts")
}
